# GEMINI_API_KEY: Required for Gemini AI API calls (for text analysis).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# YANDEX_SERVICE_ACCOUNT_KEY and YANDEX_FOLDER_ID: Required for Yandex Cloud (YandexART / YandexGPT).
YANDEX_SERVICE_ACCOUNT_KEY="MY_YANDEX_SERVICE_ACCOUNT_JSON"
YANDEX_FOLDER_ID="MY_FOLDER_ID"

# FAL_KEY: Required for Virtual Try-On face-swap and Flux generation
FAL_KEY="MY_FAL_KEY"

# TELEGRAM_BOT_TOKEN: Required for Telegram Stars monetization
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"

# TELEGRAM_ADMIN_CHAT_ID: Required for sending system logs and notifications
TELEGRAM_ADMIN_CHAT_ID="MY_TELEGRAM_ADMIN_CHAT_ID"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Firebase Client Configuration (From firebase-applet-config.json)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_DATABASE_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
