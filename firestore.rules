rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['fullAccess']) 
                        || request.resource.data.get('fullAccess', false) == resource.data.get('fullAccess', false))
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['generationsLeft']) 
                        || request.resource.data.get('generationsLeft', 0) <= resource.data.get('generationsLeft', 0));
    }
    match /{document=**} { 
      allow read, write: if false; 
    }
  }
}
